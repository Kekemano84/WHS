SECRET_KEY=change-this-secret
APP_URL=https://whs-6ozo.onrender.com

# Gmail SMTP example.
# Gmail requires a Google App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASSWORD=your_16_character_google_app_password
SMTP_FROM=your-gmail-address@gmail.com

# These common alternatives are also supported:
# SMTP_SERVER=smtp.gmail.com
# SMTP_EMAIL=your-gmail-address@gmail.com
# SMTP_APP_PASSWORD=your_16_character_google_app_password
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-gmail-address@gmail.com
# MAIL_PASSWORD=your_16_character_google_app_password
# MAIL_DEFAULT_SENDER=your-gmail-address@gmail.com
